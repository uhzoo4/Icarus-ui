{
  "queries": [
    "monitors",
    "workspaces",
    "activeworkspace",
    "clients",
    "layers",
    "cursorpos"
  ],
  "verbs": {
    "focuswindow": {
      "args": ["address"],
      "kwin_action": "w.minimized = false; workspace.activeWindow = w;"
    },
    "closewindow": {
      "args": ["address"],
      "kwin_action": "w.closeWindow();"
    },
    "killwindow": {
      "args": ["address"],
      "kwin_action": "w.closeWindow();"
    },
    "killactive": {
      "args": [],
      "kwin_action": "if (workspace.activeWindow) workspace.activeWindow.closeWindow();"
    },
    "movetoworkspace": {
      "args": ["workspace_id", "address"],
      "kwin_action": "let d = workspace.desktops[parseInt('{workspace_id}') - 1]; if (d) w.desktops = [d];"
    },
    "workspace": {
      "args": ["workspace_id"],
      "kwin_action": "let d = workspace.desktops[parseInt('{workspace_id}') - 1]; if (d) workspace.currentDesktop = d;"
    },
    "togglespecialworkspace": {
      "args": ["name"],
      "kwin_action": "/* no native special workspaces in KWin */"
    },
    "togglefloating": {
      "args": ["address"],
      "kwin_action": "w.keepAbove = !w.keepAbove;"
    },
    "pin": {
      "args": ["address"],
      "kwin_action": "w.onAllDesktops = !w.onAllDesktops;"
    },
    "dpms": {
      "args": ["state"],
      "dbus_command": "qdbus6 org.kde.Solid.PowerManagement.Actions.DpmsControl invokeAction '{state}'"
    }
  }
}
