#!/usr/bin/env bash
export PATH="$HOME/.local/bin:$PATH"

set -uo pipefail

die()  { echo "[FATAL] $*" >&2; exit 1; }
info() { echo "[INFO]  $*"; }
ok()   { echo "[OK]    $*"; }
warn() { echo "[WARN]  $*"; }

BRANCH="${1:-main}"
LIVE_BRANCHES=$(git ls-remote --heads https://github.com/ladybug-me/caelestia-dots-kde.git | awk '{print $2}' | sed 's|^refs/heads/||')
if ! echo "$LIVE_BRANCHES" | grep -q "^$BRANCH$"; then
    echo "Warning: Branch '$BRANCH' does not exist on remote. Falling back to 'main'."
    BRANCH="main"
fi
UPD_DIR="$HOME/.config/caelestia-update"

echo "---------------------------------------------"
echo "  Caelestia Update (Branch: $BRANCH)"
echo "---------------------------------------------"

# --- Pre-flight Dependency Checks ---
for cmd in git cmake make; do
    if ! command -v "$cmd" &> /dev/null; then
        die "Required command '$cmd' is missing. Please install it first."
    fi
done

# --- Robust Privilege Escalation Wrapper ---
mkdir -p "$UPD_DIR/bin"
cat << 'EOF' > "$UPD_DIR/bin/sudo"
#!/usr/bin/env bash
if [ "$EUID" -eq 0 ]; then
    "$@"
elif [ -t 1 ]; then
    /usr/bin/sudo "$@"
elif command -v ksshaskpass &> /dev/null; then
    SUDO_ASKPASS=$(command -v ksshaskpass) /usr/bin/sudo -A "$@"
elif command -v pkexec &> /dev/null; then
    pkexec "$@"
else
    echo "Cannot elevate privileges. Please install ksshaskpass, pkexec, or run from a terminal." >&2
    exit 1
fi
EOF
chmod +x "$UPD_DIR/bin/sudo"
export PATH="$UPD_DIR/bin:$PATH"

# --- Pre-flight Dependency Checks ---
for cmd in git cmake make; do
    if ! command -v "$cmd" &> /dev/null; then
        die "Required command '$cmd' is missing. Please install it first."
    fi
done

# --- Robust Privilege Escalation Wrapper ---
mkdir -p "$UPD_DIR/bin"
cat << 'EOF' > "$UPD_DIR/bin/sudo"
#!/usr/bin/env bash
if [ "$EUID" -eq 0 ]; then
    "$@"
elif [ -t 1 ]; then
    /usr/bin/sudo "$@"
elif command -v ksshaskpass &> /dev/null; then
    SUDO_ASKPASS=$(command -v ksshaskpass) /usr/bin/sudo -A "$@"
elif command -v pkexec &> /dev/null; then
    pkexec "$@"
else
    echo "Cannot elevate privileges. Please install ksshaskpass, pkexec, or run from a terminal." >&2
    exit 1
fi
EOF
chmod +x "$UPD_DIR/bin/sudo"
export PATH="$UPD_DIR/bin:$PATH"

# 1. Fetch from GitHub
echo "PROGRESS: 1/5: Fetching updates from GitHub..."
info "Checking for local repository cache..."

# --- Safe Backup Directory outside of the git repo ---
export BACKUP_DIR="$UPD_DIR/backups/$(date +%Y%m%d_%H%M%S)"
mkdir -p "$BACKUP_DIR"

if [[ ! -d "$UPD_DIR/repo/.git" ]]; then
    mkdir -p "$UPD_DIR/repo"
    cd "$UPD_DIR/repo"
    git init -q
    git remote add origin https://github.com/ladybug-me/caelestia-dots-kde.git
else
    cd "$UPD_DIR/repo"
    git reset --hard -q HEAD || die "Failed to reset repository state"
    git clean -fdx -q
    git remote set-url origin https://github.com/ladybug-me/caelestia-dots-kde.git
fi

# Always enforce sparse-checkout rules
git config core.sparseCheckout true
echo "shell/" > .git/info/sparse-checkout
echo "src/" >> .git/info/sparse-checkout
echo "scripts/" >> .git/info/sparse-checkout
echo ".gitmodules" >> .git/info/sparse-checkout

# Safer fetch and reset instead of pull
git fetch -q --depth 1 origin "$BRANCH" || die "Failed to fetch repository"
git reset --hard -q origin/"$BRANCH" || die "Failed to apply updates"


if [[ -f "$UPD_DIR/repo/.gitmodules" ]]; then
    info "Initializing src/dots submodule..."
    git submodule sync -- src/dots >/dev/null 2>&1 || true
    git submodule update --init --recursive src/dots || die "Failed to initialize src/dots submodule"
fi

[[ -f "$UPD_DIR/repo/src/dots/starship.toml" ]] || die "Missing src/dots content after update"

# 2. System update via Polkit
echo "PROGRESS: 2/5: Running system update..."
echo
echo "---------------------------------------------"
echo "  Step 1 - System Updates"
echo "---------------------------------------------"
if command -v pacman >/dev/null; then
    info "Running system update via pacman..."
    sudo pacman -Syu --noconfirm || warn "System update was canceled or failed. Continuing with non-sudo parts..."
elif command -v dnf >/dev/null; then
    info "Running system update via dnf..."
    sudo dnf upgrade --refresh -y || warn "System update was canceled or failed. Continuing with non-sudo parts..."
fi

# 3. Build script now handles GUI privilege escalation natively.
info "Executing build scripts (GUI prompts will appear if required)..."

export BUNDLE_DIR="$UPD_DIR/repo"

# 4. Deploy Configs
echo "PROGRESS: 3/5: Deploying configuration files..."
echo
echo "---------------------------------------------"
echo "  Step 2 - Deploy Configs"
echo "---------------------------------------------"
if [[ "${CAELESTIA_SKIP_DEPLOY:-0}" == "1" ]]; then
    info "Skipping deploy-configs per user settings."
else
    bash "$UPD_DIR/repo/scripts/03-deploy-configs.sh" || die "Config deployment failed."
fi

# 5. Build Shell
echo "PROGRESS: 4/5: Building Caelestia Shell UI..."
echo
echo "---------------------------------------------"
echo "  Step 3 - Build Caelestia Shell UI"
echo "---------------------------------------------"
if [[ "${CAELESTIA_SKIP_BUILD:-0}" == "1" ]]; then
    info "Skipping build-shell per user settings."
else
    bash "$UPD_DIR/repo/scripts/08-build-shell.sh" || warn "Shell build reported an error, but continuing."
fi

# 6. Save current commit hash
if [ -d "$UPD_DIR/repo/.git" ]; then
    COMMIT_HASH=$(git rev-parse HEAD)
    mkdir -p ~/.config/quickshell/caelestia
    echo "$COMMIT_HASH" > ~/.config/quickshell/caelestia/.current_commit
    info "Saved commit hash: $COMMIT_HASH"
fi

echo "PROGRESS: done: Update completed successfully"
echo
echo "---------------------------------------------"
echo "  Update Completed Successfully!"
echo "---------------------------------------------"
