#!/usr/bin/env bash
export PATH="$HOME/.local/bin:$PATH"

# This script is meant to be run periodically by a systemd timer.
# It checks for updates and sends a notification using notify-send.

# Pre-flight dependency check for silent failure
if ! command -v git &> /dev/null; then
    exit 0
fi

# Respect Nexus Settings (GlobalConfig.general.checkUpdates)
if command -v jq >/dev/null && [ -f "$HOME/.config/caelestia/shell.json" ]; then
    CHECK_UPDATES=$(jq -r '.general.checkUpdates // true' "$HOME/.config/caelestia/shell.json" 2>/dev/null)
    if [ "$CHECK_UPDATES" = "false" ]; then
        exit 0
    fi
fi

# 1. Check Caelestia UI Updates (GitHub)
REPO="$HOME/.cache/caelestia-update-repo"
BRANCH=$(cat "$HOME/.config/quickshell/caelestia/.update_branch" 2>/dev/null || echo "main")

LIVE_BRANCHES=$(git ls-remote --heads https://github.com/ladybug-me/caelestia-dots-kde.git | awk '{print $2}' | sed 's|^refs/heads/||')
if ! echo "$LIVE_BRANCHES" | grep -q "^$BRANCH$"; then
    BRANCH="main"
    mkdir -p "$HOME/.config/quickshell/caelestia"
    echo "$BRANCH" > "$HOME/.config/quickshell/caelestia/.update_branch"
fi

_localCommit="$(cat "$HOME/.config/quickshell/caelestia/.current_commit" 2>/dev/null)"
CAELESTIA_PENDING=0

if [ -n "$_localCommit" ]; then
    if [ ! -d "$REPO" ]; then
        git clone --bare --filter=blob:none https://github.com/ladybug-me/caelestia-dots-kde.git "$REPO" >/dev/null 2>&1
    else
        git -C "$REPO" fetch origin >/dev/null 2>&1
    fi

    LOCAL_DATE=$(git -C "$REPO" show -s --format=%cI ${_localCommit} 2>/dev/null)
    if [ -n "$LOCAL_DATE" ]; then
        CAELESTIA_PENDING=$(git -C "$REPO" log --oneline --since="$LOCAL_DATE" ${_localCommit}..${BRANCH} 2>/dev/null | wc -l)
    else
        CAELESTIA_PENDING=$(git -C "$REPO" log --oneline ${_localCommit}..${BRANCH} 2>/dev/null | wc -l)
    fi
fi

# 2. Check System Updates (Arch Linux & Flatpak)
SYSTEM_PENDING=0

if command -v checkupdates >/dev/null; then
    PACMAN_PENDING=$(checkupdates 2>/dev/null | wc -l)
    SYSTEM_PENDING=$((SYSTEM_PENDING + PACMAN_PENDING))
fi

if command -v flatpak >/dev/null; then
    FLATPAK_PENDING=$(flatpak remote-ls --updates 2>/dev/null | wc -l)
    SYSTEM_PENDING=$((SYSTEM_PENDING + FLATPAK_PENDING))
fi

# 3. Notification Anti-Spam & Cachy-Update Logic
CACHE_FILE="$HOME/.cache/caelestia-kde/last_update_counts"
OLD_C=0
OLD_S=0

if [ -f "$CACHE_FILE" ]; then
    read -r OLD_C OLD_S < "$CACHE_FILE"
fi

if [ "$CAELESTIA_PENDING" -gt "${OLD_C:-0}" ] || [ "$SYSTEM_PENDING" -gt "${OLD_S:-0}" ]; then
    TITLE="System Update Available"
    BODY=""
    
    if [ "$CAELESTIA_PENDING" -gt 0 ] && [ "$SYSTEM_PENDING" -gt 0 ]; then
        TITLE="System & UI Updates Available"
        BODY="$CAELESTIA_PENDING UI commits and $SYSTEM_PENDING system packages."
    elif [ "$CAELESTIA_PENDING" -gt 0 ]; then
        TITLE="Caelestia Update Available"
        BODY="$CAELESTIA_PENDING new commits on $BRANCH branch."
    elif [ "$SYSTEM_PENDING" -gt 0 ]; then
        BODY="$SYSTEM_PENDING new system packages."
    fi

    if [ -n "$BODY" ]; then
        # Cachy-update logic: Replace previous notification, add action buttons
        NOTIF_ID_FILE="$HOME/.cache/caelestia-kde/last_update_notif_id"
        LAST_ID=""
        if [ -f "$NOTIF_ID_FILE" ]; then
            LAST_ID=$(cat "$NOTIF_ID_FILE")
        fi

        NOTIF_ARGS=( -p -u normal -i system-software-update -a "Caelestia Updates" )
        if [ -n "$LAST_ID" ]; then
            NOTIF_ARGS+=( -r "$LAST_ID" )
        fi
        
        NOTIF_ARGS+=( -A "run=Install Updates" -A "close=Close" )
        
        # This will block until the user clicks an action or dismisses it
        NOTIF_OUT=$(notify-send "${NOTIF_ARGS[@]}" "$TITLE" "$BODY")
        
        # Save new ID (first line of output) for next time
        echo "$NOTIF_OUT" | head -n 1 > "$NOTIF_ID_FILE"
        
        # Extract the clicked action
        ACTION=$(echo "$NOTIF_OUT" | sed -n '2p')
        if [ "$ACTION" = "run" ]; then
            if [ -x "$HOME/.local/bin/caelestia" ]; then
                "$HOME/.local/bin/caelestia" shell toggleNexus &
            elif command -v caelestia &> /dev/null; then
                caelestia shell toggleNexus &
            fi
        fi
    fi
fi

# Always save the new counts
mkdir -p "$(dirname "$CACHE_FILE")"
echo "$CAELESTIA_PENDING $SYSTEM_PENDING" > "$CACHE_FILE"
